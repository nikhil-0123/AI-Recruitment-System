# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=AI Recruitment Automation System
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# ── Database (localhost PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aras_user:aras_password@localhost:5432/aras_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── Security (required in future sprints — add now to avoid refactor) ──────────
SECRET_KEY=change-me-to-a-random-64-char-string-before-any-auth-work
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30